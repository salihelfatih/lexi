# Database
DATABASE_URL=postgresql://lexi:lexi@localhost:5432/lexi

# Redis
REDIS_URL=redis://localhost:6379/0

# S3 Storage
S3_ENDPOINT_URL=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET_NAME=lexi-documents
S3_REGION=us-east-1

# Encryption
MASTER_ENCRYPTION_KEY=your-32-byte-base64-encoded-key-here

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

# API
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000"]

# Processing
MAX_FILE_SIZE_MB=50
EPHEMERAL_TTL_MINUTES=5
TEXT_EXTRACTION_TIMEOUT_SECONDS=120
OCR_TIMEOUT_SECONDS=300
CLASSIFICATION_TIMEOUT_SECONDS=30
CLAUSE_EXTRACTION_TIMEOUT_SECONDS=60

# ML Models
HF_MODEL_NAME=distilbert-base-uncased
SPACY_MODEL_NAME=en_core_web_sm

# RAG Vector Backend
RAG_VECTOR_BACKEND=qdrant
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=
QDRANT_COLLECTION_NAME=lexi_documents
QDRANT_VECTOR_SIZE=384
QDRANT_DISTANCE=cosine

# LLM summaries
# Use fake for deterministic local tests. Use ollama for a local real provider.
LLM_PROVIDER=fake
LLM_MODEL_NAME=fake-grounded-summary-v1
LLM_BASE_URL=
LLM_REQUEST_TIMEOUT_SECONDS=30
LLM_SUMMARY_MAX_CONTEXT_CHARS=8000
LLM_SUMMARY_MIN_EXTRACTION_CONFIDENCE=50

# Logging
LOG_LEVEL=INFO

# Auth
# Private MVP uses the built-in custom JWT provider.
# Public beta decision: Supabase Auth. Keep custom locally until frontend cutover.
AUTH_PROVIDER=custom
JWT_SECRET_KEY=change-this-secret-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Supabase Auth, not active while AUTH_PROVIDER=custom.
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_JWKS_URL=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_JWKS_CACHE_SECONDS=600

# Frontend auth.
# Keep custom for private MVP/E2E. Set supabase with the public values below for public beta.
NEXT_PUBLIC_AUTH_PROVIDER=custom
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
